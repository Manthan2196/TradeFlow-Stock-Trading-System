# Flask server
PORT=4000
NODE_ENV=development

# JWT signing secret for local development.
# Change this before deploying.
JWT_SECRET=change_me_tradeflow_secret

# Optional: set this for PostgreSQL/Supabase.
# Leave empty to use the local SQLite database generated by init_db.py.
DATABASE_URL=

# Optional SQLite filename inside backend/.
SQLITE_PATH=tradeflow.db
